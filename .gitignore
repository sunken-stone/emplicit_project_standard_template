# Always Ensure that your files that need to be hidden by .gitignore match these file names 
# DO NOT add .claude/ to your gitignore - needs to able to save session ID's

# Environment
#.env file is where you store all private keys, document IDs for functions, and API Keys. mandatory or your Keys will be exposed to internet and I will deactivate them. 
.env
.env.local

# Python
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# JavaScript / Node
node_modules/
dist/
.next/
coverage/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
